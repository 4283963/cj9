# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis Performance Tuning
REDIS_SCAN_COUNT=100
REDIS_BATCH_SIZE=50
REDIS_THROTTLE_MS=10

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=retroshooter
POSTGRES_PASSWORD=retroshooter
POSTGRES_DB=retroshooter
POSTGRES_SSLMODE=disable

# PostgreSQL Performance Tuning
POSTGRES_BATCH_SIZE=100

# Archive Service Configuration
ARCHIVE_CRON=0 0 1 * * *
ARCHIVE_DAYS_TO_KEEP=30
BATCH_SIZE=100
REDIS_KEY_PREFIX=game:detail:
TIME_ZONE=Asia/Shanghai

# Java Server Configuration
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
